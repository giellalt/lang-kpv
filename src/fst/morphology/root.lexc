!! ## Lexicon Root
LEXICON Root

!! The word forms in Komi (Zyrian) language start from the lexeme roots of basic
!! word classes, or optionally from prefixes:
  SUBSTANDARDS ; !!вүҲ * @CODE@  temporary solution
              adjectives                         ; !!вүҲ * @CODE@ 
              kom-adjectives-russian-like        ; !!вүҲ * @CODE@ 
              adpositions                        ; !!вүҲ * @CODE@ 
              adverbs                            ; !!вүҲ * @CODE@ 
              conjunctors                        ; !!вүҲ * @CODE@ 
              descriptives                       ; !!вүҲ * @CODE@ 
              determiners                        ; !!вүҲ * @CODE@ 
              gerunds                            ; !!вүҲ * @CODE@ 
              interjections                      ; !!вүҲ * @CODE@ 
!              nouns-deverbal                     ; !!вүҲ * @CODE@ 
              nouns                              ; !!вүҲ * @CODE@ 
!              nouns-russian-homographs           ; !!вүҲ * @CODE@ 
              numerals                           ; !!вүҲ * @CODE@ 
              particles                          ; !!вүҲ * @CODE@ 
              pronouns                           ; !!вүҲ * @CODE@ 
              propernouns-malenames-cyrillic     ; !!вүҲ * @CODE@ 
              propernouns-malesurnames-cyrillic  ; !!вүҲ * @CODE@ 
              propernouns-toponyms-Russian       ; !!вүҲ * @CODE@ 2019-10-30 Cyrillic
  @U.Cap.Obl@ propernouns-toponyms-Komi          ; !!вүҲ * @CODE@  toponyms - always uppercase
  @U.Cap.Opt@ propernouns-toponyms-Komi          ; !!вүҲ * @CODE@  toponyms - allow downcasing for adj derivation
              propernouns                        ; !!вүҲ * @CODE@ 
              quantifiers                        ; !!вүҲ * @CODE@ 
              subjunctors                        ; !!вүҲ * @CODE@ 
              verbs-A2M                          ; !!вүҲ * @CODE@ 
              verbs-N2END                        ; !!вүҲ * @CODE@ 
              VERBNEGATIVE                       ; !!вүҲ * @CODE@  affixes/verbs.lexc
              PRONOUN-TYPES                      ; !!вүҲ * @CODE@  in affixes/pronouns.lexc 2019-04-06
              Abbreviation                       ; !!вүҲ * @CODE@ 
              Acronym                            ; !!вүҲ * @CODE@ 
              kpv-Acronym                        ; !!вүҲ * @CODE@ 
              Punctuation                        ; !!вүҲ * @CODE@ 
              Symbols                            ; !!вүҲ * @CODE@ 
              EXCEPTIONS                         ; !!вүҲ * @CODE@ 
              dialect_lexicon                    ; !!вүҲ * @CODE@ 
              urj-Cyrl-ProperNouns               ; !!вүҲ * @CODE@ ! Testing 2015-09-06
             A_NEWWORDS              ;             !!вүҲ * @CODE@ 
             ADV_NEWWORDS            ;             !!вүҲ * @CODE@ 
             N_NEWWORDS              ;             !!вүҲ * @CODE@ 
 @U.Cap.Obl@ PROP_NEWWORDS           ;             !!вүҲ * @CODE@ 
 @U.Cap.Opt@ PROP_NEWWORDS           ;             !!вүҲ * @CODE@ 
             V_NEWWORDS              ;             !!вүҲ * @CODE@ 


! ======================================================= !
!! ### Lexica without morphology !
! ======================================================= !

!! Absolute forms
LEXICON ABS_
!! @LEXNAME@
 +Abs: # ;
!! РҝСғ РәРөСҖРәР°
!! РІСӢР»СҢ РәРөСҖРәР°


!! ### Compounding

LEXICON R
!! @LEXNAME@
+Cmp#:%-# nouns ;
+Cmp#:%-# N_NEWWORDS ;
!+Cmp#:%-# nouns-deverbal ;

LEXICON Serial-Verbs
!! @LEXNAME@
+Cmp/Serial+Cmp#:%-# verbs-A2M ;
+Cmp/Serial+Cmp#:%-# verbs-N2END ;
+Cmp/Serial+Cmp#:%-# V_NEWWORDS ;



!  ==================================== !
!! ### Lexica called End, whatever they are 
!  ==================================== !

LEXICON ABBR-IS_ADV
!! @LEXNAME@
+ABBR: ADV_ ;

LEXICON ABBR-IS_N
!! @LEXNAME@
+ABBR+N: WordEnd ; ! This needs a Noun1 continuation but the hyphen must
             ! be dealt with for non-nominative-singular marking 2012-01-27

!2018-10-21!LEXICON EndNeg
!2018-10-21!+CC+Neg: WordEnd ; ! РҪРё

!LEXICON EndQST
!+Qst: WordEnd ;


! ======= !
!! ### Clitics 
! ======= !

LEXICON K
!! @LEXNAME@
 WordEnd ;
+Clt/toe:%>СӮУ§ WordEnd ;
+Clt/soe:%>СҒУ§ WordEnd ;
+Clt/toe+Err/Orth-e-not-oe+Err/Dial:%>СӮСҚ WordEnd ;
+Clt/toe+Err/Orth-o-not-oe+Err/Dial:%>СӮРҫ WordEnd ;
+Clt/soe+Err/Orth-e-not-oe+Err/Dial:%>СҒСҚ WordEnd ;

! For this all instances of _#_
! were converted to _WordEnd_
LEXICON WordEnd
!! @LEXNAME@
            # ;
+Qst/A:%>%-Р° WordEnd-2 ;
+Qst/Oe:%>%-У§ WordEnd-2 ;
+Qst/Oe:%>%-СҚ WordEnd-2 ;

LEXICON WordEnd-2
!! @LEXNAME@
            # ;
+Clt/I:%-Рҳ2 # ;

! List of spurious lexica
! These should be fixed.

!2018-10-21!LEXICON ADV-SUPERL
!2018-10-21!+Adv+Superl: WordEnd ;

! 2012-02-11
! This should have the following case forms pointing toward it:
! ine, ill, ela, apr, aprela, aprill, aprine
LEXICON SPAT-COMPARATIVE
!! @LEXNAME@
 COMPARATIVE ;
 PredMonLex-Spat-Add-Morphology ; !

LEXICON COMPARATIVE
!! @LEXNAME@
               K ;
+Comp:%>РҙР¶СӢРә K ; !more
+Der+Der/РјРҫР·:%>РјРҫР· K ; ! like -- in verbal constructions (Jaska thinks 2018-10-21)
+Der+Der/РәРҫРҙСҢ:%>РәРҫРҙСҢ K ; ! like -- in copula constructions

! TODO: Integrate this in xml-files in workingвҖҰ


LEXICON SUBSTANDARDS
!! @LEXNAME@
РәРҫСҖСҠСҸ+Err/Orth:РәРҫСҖСҢСҸ Noun1 ;

!! ## Endlex

LEXICON ENDLEX
!! Lexicon @LEXNAME@
!! And this is the @LEXNAME@ of everything:

   @D.CmpOnly.FALSE@@D.CmpPref.TRUE@@D.NeedNoun.ON@ # ; !!вүҲ @CODE@
! @D.Need3Part.ON@ # ; !3part
!! The `@D.CmpOnly.FALSE@` flag diacritic is ued to disallow words tagged
!! with +CmpNP/Only to end here.
!! The `@D.NeedNoun.ON@` flag diacritic is used to block illegal compounds.


! vim: set ft=xfst-lexc:
