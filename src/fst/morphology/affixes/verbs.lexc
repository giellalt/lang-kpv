

! ====================================== !
!! # Verbal morphology               
! ====================================== !

!! ## Temporary lexicon

LEXICON V_
!! @LEXNAME@ temporary lexicon gives +V+WORK
+V+WORK: # ;

!! ## Closed class verbs
! ------------------

LEXICON VERBNEGATIVE
!! @LEXNAME@ 
! Present Neg
РҫР·+V+Neg+Ind+Prs+Sg1:РҫРі MatrixVerb-Comparison ;
РҫР·+V+Neg+Ind+Prs+Sg2:РҫРҪ MatrixVerb-Comparison ;
РҫР·+V+Neg+Ind+Prs+Sg3:РҫР· MatrixVerb-Comparison ;
РҫР·+V+Neg+Ind+Prs+Pl1:РҫРіУ§ MatrixVerb-Comparison ;
РҫР·+V+Neg+Ind+Prs+Pl2:РҫРҪУ§ MatrixVerb-Comparison ;
РҫР·+V+Neg+Ind+Prs+Pl1:РҫРіУ§Р№ MatrixVerb-Comparison ;
РҫР·+V+Neg+Ind+Prs+Pl2:РҫРҪУ§Р№ MatrixVerb-Comparison ;
РҫР·+V+Neg+Ind+Prs+Pl3:РҫР· MatrixVerb-Comparison ;

РҫР·+Use/NG+Err/Dial+V+Neg+Ind+Prs+Pl1:РҫРіРө MatrixVerb-Comparison ;
РҫР·+Use/NG+Err/Dial+V+Neg+Ind+Prs+Pl2:РҫРҪСҚ MatrixVerb-Comparison ;
РҫР·+Use/NG+Err/Dial+V+Neg+Ind+Prs+Pl1:РҫРіРөР№ MatrixVerb-Comparison ;
РҫР·+Use/NG+Err/Dial+V+Neg+Ind+Prs+Pl2:РҫРҪСҚР№ MatrixVerb-Comparison ;

!Past Neg
РҫР·+V+Neg+Ind+Prt1+Sg1:СҚРі MatrixVerb-Comparison ;
РҫР·+V+Neg+Ind+Prt1+Sg2:СҚРҪ MatrixVerb-Comparison ;
РҫР·+V+Neg+Ind+Prt1+Sg3:СҚР· MatrixVerb-Comparison ;
РҫР·+V+Neg+Ind+Prt1+Pl1:СҚРі MatrixVerb-Comparison ;
РҫР·+V+Neg+Ind+Prt1+Pl2:СҚРҪ MatrixVerb-Comparison ;
РҫР·+V+Neg+Ind+Prt1+Pl1:СҚРіУ§ MatrixVerb-Comparison ;
РҫР·+V+Neg+Ind+Prt1+Pl2:СҚРҪУ§ MatrixVerb-Comparison ;
РҫР·+V+Neg+Ind+Prt1+Pl3:СҚР· MatrixVerb-Comparison ;
РҫР·+Use/NG+Err/Dial+V+Neg+Ind+Prt1+Pl1:СҚРіРө MatrixVerb-Comparison ;
РҫР·+Use/NG+Err/Dial+V+Neg+Ind+Prt1+Pl2:СҚРҪСҚ MatrixVerb-Comparison ;

!Past Neg Err/Dial
РҫР·+V+Neg+Ind+Prt1+Sg1+Use/NG+Err/Dial:РёРі MatrixVerb-Comparison ;
РҫР·+V+Neg+Ind+Prt1+Sg2+Use/NG+Err/Dial:РёРҪ MatrixVerb-Comparison ;
РҫР·+V+Neg+Ind+Prt1+Sg3+Use/NG+Err/Dial:РёР· MatrixVerb-Comparison ;
РҫР·+V+Neg+Ind+Prt1+Pl1+Use/NG+Err/Dial:РёРі MatrixVerb-Comparison ;
РҫР·+V+Neg+Ind+Prt1+Pl2+Use/NG+Err/Dial:РёРҪ MatrixVerb-Comparison ;
РҫР·+V+Neg+Ind+Prt1+Pl1+Use/NG+Err/Dial:РёРіРө MatrixVerb-Comparison ;
РҫР·+V+Neg+Ind+Prt1+Pl2+Use/NG+Err/Dial:РёРҪСҚ MatrixVerb-Comparison ;
РҫР·+V+Neg+Ind+Prt1+Pl3+Use/NG+Err/Dial:РёР· MatrixVerb-Comparison ;
РҫР·+Use/NG+Err/Dial+V+Neg+Ind+Prt1+Pl1+Err/Dial:РёРіРө MatrixVerb-Comparison ;
РҫР·+Use/NG+Err/Dial+V+Neg+Ind+Prt1+Pl2+Err/Dial:РёРҪСҚ MatrixVerb-Comparison ;

!Imperative
РҫР·+V+Neg+Imprt+Sg2:СҚРҪ K ;
РҫР·+V+Neg+Imprt+Pl2:СҚРҪ K ;
РҫР·+V+Neg+Imprt+Pl2:СҚРҪУ§ K ;
РҫР·+V+Neg+Imprt+Pl2:СҚРҪУ§Р№ K ;
РҫР·+Use/NG+Err/Dial+V+Neg+Imprt+Pl2:СҚРҪСҚ K ;
!A tag is needed to indicate this clitic-like Р»СӢ segment
РҫР·+V+Neg+Imprt+Sg2:СҚРҪР»СӢ K ;
РҫР·+V+Neg+Imprt+Pl2:СҚРҪР»У§Р№ K ;

!Final
РјРҫР·+V+Neg+Final+1:РјРҫРі K ; ! РјРөРҙ РҫРі _so that I/we won't_
РјРҫР·+V+Neg+Final+2:РјРҫРҪ K ; ! РјРөРҙ РҫРҪ
РјРҫР·+V+Neg+Final+3:РјРҫР· K ; ! РјРөРҙ РҫР·

! Negative copula supletive present forms
!Р°РұСғ+V+Neg+Cop+Ind+Sg:Р°РұСғ K ; ! Aux these are supletive. Past is СҚР· РІУ§РІ
!Р°РұСғ+V+Neg+Cop+Ind+Pl:Р°РұСғУ§СҒСҢ K ; ! Aux these are supletive. Past is СҚР· РІУ§РІРҪСӢ



!! ## Open class verbs
! ----------------

!! Some Flag diacritic lines are with regexes, other with aligned zeros. We want to migrate to
!! regexes < вҖҰ > , for readability reasons (sic!)

LEXICON IV_РӣРһРҡРқР«
!! @LEXNAME@ 
@U.CONJ-VAL.IV@+IV:@U.CONJ-VAL.IV@ V-0_РӣРһРҡРқР« ;
!2018-10-21!LEXICON TV_РӣРһРҡРқР«
!2018-10-21!+TV: V-0_РӣРһРҡРқР« ;
!2018-10-21!LEXICON BV_РӣРһРҡРқР«
!2018-10-21!+IV: V-0_РӣРһРҡРқР« ;
!2018-10-21!+TV: V-0_РӣРһРҡРқР« ;

!2018-10-21!LEXICON V_РӣРһРҡРқР« !!вүҲ * __@CODE@__ One verb only, Р»РҫРәРҪСӢ:Р»РҫРә
!2018-10-21!+IV:  V-0_РӣРһРҡРқР« ;
LEXICON V-0_РӣРһРҡРқР« !!вүҲ * **@CODE@** One verb only, Р»РҫРәРҪСӢ:Р»РҫРә
@U.CONJ-INF.YES@+Inf:@U.CONJ-INF.YES@%>РҪСӢ VerbEnd-Comparison ;
@U.CONJ-INF.YES@+Inf+Err/Dial:@U.CONJ-INF.YES@%>РҪС– VerbEnd-Comparison ;
@U.CONJ-INF.YES@@U.CONJ-POSS.1@+Inf+Px1:@U.CONJ-INF.YES@@U.CONJ-POSS.1@%>РҪСӢРј VerbEnd-Comparison ;
@U.CONJ-INF.YES@@U.CONJ-POSS.2@+Inf+Px2:@U.CONJ-INF.YES@@U.CONJ-POSS.2@%>РҪСӢРҙ VerbEnd-Comparison ;
@U.CONJ-INF.YES@@U.CONJ-POSS.3@+Inf+Px3:@U.CONJ-INF.YES@@U.CONJ-POSS.3@%>РҪСӢСҒ VerbEnd-Comparison ;
@U.CONJ-INF.YES@@U.CONJ-POSS.2ACC@+Inf+Px2+Acc:@U.CONJ-INF.YES@@U.CONJ-POSS.2ACC@%>РҪСӢСӮУ§ VerbEnd-Comparison ;
@U.CONJ-INF.YES@@U.CONJ-POSS.3ACC@+Inf+Px3+Acc:@U.CONJ-INF.YES@@U.CONJ-POSS.3ACC@%>РҪСӢСҒУ§ VerbEnd-Comparison ;
@U.CONJ-INF.YES@@U.CONJ-POSS.2ACC@+Use/NG+Err/Dial+Inf+Px2+Acc:@U.CONJ-INF.YES@@U.CONJ-POSS.2ACC@%>РҪСӢСӮСҚ VerbEnd-Comparison ;
@U.CONJ-INF.YES@@U.CONJ-POSS.3ACC@+Use/NG+Err/Dial+Inf+Px3+Acc:@U.CONJ-INF.YES@@U.CONJ-POSS.3ACC@%>РҪСӢСҒСҚ VerbEnd-Comparison ;
@U.CONJ-INF.NO@@U.CONJ-CONNEG.YES@@U.CONJ-NX.PL@@U.CONJ-PX.3@+ConNeg+Pl3:@U.CONJ-INF.NO@@U.CONJ-CONNEG.YES@@U.CONJ-NX.PL@@U.CONJ-PX.3@%>РҪСӢ VerbEnd ;
@U.CONJ-INF.NO@@U.CONJ-CONNEG.YES@+ConNeg:@U.CONJ-INF.NO@@U.CONJ-CONNEG.YES@ VerbEnd ;
@U.CONJ-INF.NO@@U.CONJ-MX.IMP@@U.CONJ-NX.SG@@U.CONJ-PX.2@+Imprt+Sg2:@U.CONJ-INF.NO@@U.CONJ-MX.IMP@@U.CONJ-NX.SG@@U.CONJ-PX.2@ VerbEnd ;
@U.CONJ-INF.YES@:@U.CONJ-INF.YES@%>СӮ VerbDer_РҡРЈРўРқР« ; !
@U.CONJ-INF.YES@:@U.CONJ-INF.YES@%>СӮ VerbDer-V ; !
:СӮ  VerbConj_РҡРЈРўРқР« ; !Р°
@U.CONJ-INF.YES@:@U.CONJ-INF.YES@СӮ VerbDer-ONSET_Рҳ/РҶ ;


LEXICON VR_РЁРЈРқР« !!вүҲ * **@CODE@** 
@U.CONJ-INF.YES@@U.CONJ-VAL.IV@+Refl:@U.CONJ-INF.YES@@U.CONJ-VAL.IV@ Verb-nyDer ; !
@U.CONJ-INF.YES@@U.CONJ-VAL.IV@+Refl:@U.CONJ-INF.YES@@U.CONJ-VAL.IV@ VerbDer ; !
@U.CONJ-INF.YES@@U.CONJ-VAL.IV@+Refl:@U.CONJ-INF.YES@@U.CONJ-VAL.IV@ VerbDer-V ; !
+Refl: VerbConj ; !Р°
+Refl: VerbConj-V ; !Рұ
@U.CONJ-INF.YES@@U.CONJ-VAL.IV@+Refl:@U.CONJ-INF.YES@@U.CONJ-VAL.IV@  VerbDer-ONSET_Рҳ/РҶ ;
@U.CONJ-INF.YES@@U.CONJ-VAL.IV@+Refl:@U.CONJ-INF.YES@@U.CONJ-VAL.IV@Р° Verb-nyDer-ONSET-Рҗ ;

