

! ====================================== !
!! # Verbal morphology               
! ====================================== !

!! ## Temporary lexicon

LEXICON V_
!! @LEXNAME@ temporary lexicon gives +V+WORK
+V+WORK: # ;

!! ## Closed class verbs
! ------------------

LEXICON VERBNEGATIVE
!! @LEXNAME@ 
! Present Neg
–ĺ–∑+V+Neg+Ind+Prs+Sg1:–ĺ–≥ MatrixVerb_Comparison ;
–ĺ–∑+V+Neg+Ind+Prs+Sg2:–ĺ–Ĺ MatrixVerb_Comparison ;
–ĺ–∑+V+Neg+Ind+Prs+Sg3:–ĺ–∑ MatrixVerb_Comparison ;
–ĺ–∑+V+Neg+Ind+Prs+Pl1:–ĺ–≥”ß MatrixVerb_Comparison ;
–ĺ–∑+V+Neg+Ind+Prs+Pl2:–ĺ–Ĺ”ß MatrixVerb_Comparison ;
–ĺ–∑+V+Neg+Ind+Prs+Pl1:–ĺ–≥”ß–Ļ MatrixVerb_Comparison ;
–ĺ–∑+V+Neg+Ind+Prs+Pl2:–ĺ–Ĺ”ß–Ļ MatrixVerb_Comparison ;
–ĺ–∑+V+Neg+Ind+Prs+Pl3:–ĺ–∑ MatrixVerb_Comparison ;

–ĺ–∑+Use/NG+Err/Dial+V+Neg+Ind+Prs+Pl1:–ĺ–≥–Ķ MatrixVerb_Comparison ;
–ĺ–∑+Use/NG+Err/Dial+V+Neg+Ind+Prs+Pl2:–ĺ–Ĺ—ć MatrixVerb_Comparison ;
–ĺ–∑+Use/NG+Err/Dial+V+Neg+Ind+Prs+Pl1:–ĺ–≥–Ķ–Ļ MatrixVerb_Comparison ;
–ĺ–∑+Use/NG+Err/Dial+V+Neg+Ind+Prs+Pl2:–ĺ–Ĺ—ć–Ļ MatrixVerb_Comparison ;

!Past Neg
–ĺ–∑+V+Neg+Ind+Prt1+Sg1:—ć–≥ MatrixVerb_Comparison ;
–ĺ–∑+V+Neg+Ind+Prt1+Sg2:—ć–Ĺ MatrixVerb_Comparison ;
–ĺ–∑+V+Neg+Ind+Prt1+Sg3:—ć–∑ MatrixVerb_Comparison ;
–ĺ–∑+V+Neg+Ind+Prt1+Pl1:—ć–≥ MatrixVerb_Comparison ;
–ĺ–∑+V+Neg+Ind+Prt1+Pl2:—ć–Ĺ MatrixVerb_Comparison ;
–ĺ–∑+V+Neg+Ind+Prt1+Pl1:—ć–≥”ß MatrixVerb_Comparison ;
–ĺ–∑+V+Neg+Ind+Prt1+Pl2:—ć–Ĺ”ß MatrixVerb_Comparison ;
–ĺ–∑+V+Neg+Ind+Prt1+Pl3:—ć–∑ MatrixVerb_Comparison ;
–ĺ–∑+Use/NG+Err/Dial+V+Neg+Ind+Prt1+Pl1:—ć–≥–Ķ MatrixVerb_Comparison ;
–ĺ–∑+Use/NG+Err/Dial+V+Neg+Ind+Prt1+Pl2:—ć–Ĺ—ć MatrixVerb_Comparison ;

!Past Neg Err/Dial
–ĺ–∑+V+Neg+Ind+Prt1+Sg1+Use/NG+Err/Dial:–ł–≥ MatrixVerb_Comparison ;
–ĺ–∑+V+Neg+Ind+Prt1+Sg2+Use/NG+Err/Dial:–ł–Ĺ MatrixVerb_Comparison ;
–ĺ–∑+V+Neg+Ind+Prt1+Sg3+Use/NG+Err/Dial:–ł–∑ MatrixVerb_Comparison ;
–ĺ–∑+V+Neg+Ind+Prt1+Pl1+Use/NG+Err/Dial:–ł–≥ MatrixVerb_Comparison ;
–ĺ–∑+V+Neg+Ind+Prt1+Pl2+Use/NG+Err/Dial:–ł–Ĺ MatrixVerb_Comparison ;
–ĺ–∑+V+Neg+Ind+Prt1+Pl1+Use/NG+Err/Dial:–ł–≥–Ķ MatrixVerb_Comparison ;
–ĺ–∑+V+Neg+Ind+Prt1+Pl2+Use/NG+Err/Dial:–ł–Ĺ—ć MatrixVerb_Comparison ;
–ĺ–∑+V+Neg+Ind+Prt1+Pl3+Use/NG+Err/Dial:–ł–∑ MatrixVerb_Comparison ;
–ĺ–∑+Use/NG+Err/Dial+V+Neg+Ind+Prt1+Pl1+Err/Dial:–ł–≥–Ķ MatrixVerb_Comparison ;
–ĺ–∑+Use/NG+Err/Dial+V+Neg+Ind+Prt1+Pl2+Err/Dial:–ł–Ĺ—ć MatrixVerb_Comparison ;

!Imperative
–ĺ–∑+V+Neg+Imprt+Sg2:—ć–Ĺ K ;
–ĺ–∑+V+Neg+Imprt+Pl2:—ć–Ĺ K ;
–ĺ–∑+V+Neg+Imprt+Pl2:—ć–Ĺ”ß K ;
–ĺ–∑+V+Neg+Imprt+Pl2:—ć–Ĺ”ß–Ļ K ;
–ĺ–∑+Use/NG+Err/Dial+V+Neg+Imprt+Pl2:—ć–Ĺ—ć K ;
!A tag is needed to indicate this clitic-like –Ľ—č segment
–ĺ–∑+V+Neg+Imprt+Sg2:—ć–Ĺ–Ľ—č K ;
–ĺ–∑+V+Neg+Imprt+Pl2:—ć–Ĺ–Ľ”ß–Ļ K ;

!Final
–ľ–ĺ–∑+V+Neg+Final+1:–ľ–ĺ–≥ K ; ! –ľ–Ķ–ī –ĺ–≥ _so that I/we won't_
–ľ–ĺ–∑+V+Neg+Final+2:–ľ–ĺ–Ĺ K ; ! –ľ–Ķ–ī –ĺ–Ĺ
–ľ–ĺ–∑+V+Neg+Final+3:–ľ–ĺ–∑ K ; ! –ľ–Ķ–ī –ĺ–∑

! Negative copula supletive present forms
!–į–Ī—É+V+Neg+Cop+Ind+Sg:–į–Ī—É K ; ! Aux these are supletive. Past is —ć–∑ –≤”ß–≤
!–į–Ī—É+V+Neg+Cop+Ind+Pl:–į–Ī—É”ß—Ā—Ć K ; ! Aux these are supletive. Past is —ć–∑ –≤”ß–≤–Ĺ—č



!! ## Open class verbs
! ----------------

!! Some Flag diacritic lines are with regexes, other with aligned zeros. We want to migrate to
!! regexes < ‚Ä¶ > , for readability reasons (sic!)

LEXICON IV_–õ–ě–ö–Ě–ę
!! @LEXNAME@ 
@U.CONJ-VAL.IV@+IV:@U.CONJ-VAL.IV@ V_0_–õ–ě–ö–Ě–ę ;
!2018-10-21!LEXICON TV_–õ–ě–ö–Ě–ę
!2018-10-21!+TV: V_0_–õ–ě–ö–Ě–ę ;
!2018-10-21!LEXICON BV_–õ–ě–ö–Ě–ę
!2018-10-21!+IV: V_0_–õ–ě–ö–Ě–ę ;
!2018-10-21!+TV: V_0_–õ–ě–ö–Ě–ę ;

!2018-10-21!LEXICON V_–õ–ě–ö–Ě–ę !!‚Čą * __@CODE@__ One verb only, –Ľ–ĺ–ļ–Ĺ—č:–Ľ–ĺ–ļ
!2018-10-21!+IV:  V_0_–õ–ě–ö–Ě–ę ;
LEXICON V_0_–õ–ě–ö–Ě–ę !!‚Čą * **@CODE@** One verb only, –Ľ–ĺ–ļ–Ĺ—č:–Ľ–ĺ–ļ
@U.CONJ-INF.YES@+Inf:@U.CONJ-INF.YES@%>–Ĺ—č VerbEnd_Comparison ;
@U.CONJ-INF.YES@+Inf+Err/Dial:@U.CONJ-INF.YES@%>–Ĺ—Ė VerbEnd_Comparison ;
@U.CONJ-INF.YES@@U.CONJ-POSS.1@+Inf+Px1:@U.CONJ-INF.YES@@U.CONJ-POSS.1@%>–Ĺ—č–ľ VerbEnd_Comparison ;
@U.CONJ-INF.YES@@U.CONJ-POSS.2@+Inf+Px2:@U.CONJ-INF.YES@@U.CONJ-POSS.2@%>–Ĺ—č–ī VerbEnd_Comparison ;
@U.CONJ-INF.YES@@U.CONJ-POSS.3@+Inf+Px3:@U.CONJ-INF.YES@@U.CONJ-POSS.3@%>–Ĺ—č—Ā VerbEnd_Comparison ;
@U.CONJ-INF.YES@@U.CONJ-POSS.2ACC@+Inf+Px2+Acc:@U.CONJ-INF.YES@@U.CONJ-POSS.2ACC@%>–Ĺ—č—ā”ß VerbEnd_Comparison ;
@U.CONJ-INF.YES@@U.CONJ-POSS.3ACC@+Inf+Px3+Acc:@U.CONJ-INF.YES@@U.CONJ-POSS.3ACC@%>–Ĺ—č—Ā”ß VerbEnd_Comparison ;
@U.CONJ-INF.YES@@U.CONJ-POSS.2ACC@+Use/NG+Err/Dial+Inf+Px2+Acc:@U.CONJ-INF.YES@@U.CONJ-POSS.2ACC@%>–Ĺ—č—ā—ć VerbEnd_Comparison ;
@U.CONJ-INF.YES@@U.CONJ-POSS.3ACC@+Use/NG+Err/Dial+Inf+Px3+Acc:@U.CONJ-INF.YES@@U.CONJ-POSS.3ACC@%>–Ĺ—č—Ā—ć VerbEnd_Comparison ;
@U.CONJ-INF.NO@@U.CONJ-CONNEG.YES@@U.CONJ-NX.PL@@U.CONJ-PX.3@+ConNeg+Pl3:@U.CONJ-INF.NO@@U.CONJ-CONNEG.YES@@U.CONJ-NX.PL@@U.CONJ-PX.3@%>–Ĺ—č VerbEnd ;
@U.CONJ-INF.NO@@U.CONJ-CONNEG.YES@+ConNeg:@U.CONJ-INF.NO@@U.CONJ-CONNEG.YES@ VerbEnd ;
@U.CONJ-INF.NO@@U.CONJ-MX.IMP@@U.CONJ-NX.SG@@U.CONJ-PX.2@+Imprt+Sg2:@U.CONJ-INF.NO@@U.CONJ-MX.IMP@@U.CONJ-NX.SG@@U.CONJ-PX.2@ VerbEnd ;
@U.CONJ-INF.YES@:@U.CONJ-INF.YES@%>—ā VerbDer_–ö–£–Ę–Ě–ę ; !
@U.CONJ-INF.YES@:@U.CONJ-INF.YES@%>—ā VerbDer_V ; !
:—ā  VerbConj_–ö–£–Ę–Ě–ę ; !–į
@U.CONJ-INF.YES@:@U.CONJ-INF.YES@—ā VerbDer_ONSET_–ė/–Ü ;


LEXICON VR_–®–£–Ě–ę !!‚Čą * **@CODE@** 
@U.CONJ-INF.YES@@U.CONJ-VAL.IV@+Refl:@U.CONJ-INF.YES@@U.CONJ-VAL.IV@ Verb_nyDer ; !
@U.CONJ-INF.YES@@U.CONJ-VAL.IV@+Refl:@U.CONJ-INF.YES@@U.CONJ-VAL.IV@ VerbDer ; !
